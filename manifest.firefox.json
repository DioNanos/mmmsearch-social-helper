{
  "manifest_version": 2,
  "name": "MmmSearch Social Helper",
  "description": "Enriches Instagram and Facebook profile scans using the local logged-in browser session.",
  "version": "0.2.0",
  "permissions": [
    "tabs",
    "storage",
    "https://www.instagram.com/*",
    "https://www.facebook.com/*",
    "https://m.facebook.com/*",
    "https://mmmbuto.com/*",
    "https://www.mmmbuto.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://mmmbuto.com/*",
        "https://www.mmmbuto.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.facebook.com/*",
        "https://m.facebook.com/*"
      ],
      "js": ["page-extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "browser_action": {
    "default_title": "MmmSearch Social Helper",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mmmsearch-social-helper@dionanos.github.io"
    }
  }
}
